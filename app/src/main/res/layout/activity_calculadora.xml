<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="20dp">


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatarCalc"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="#4FC3F7"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTituloCalc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CALCULADORA DSM"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4FC3F7"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@id/avatarCalc"
        app:layout_constraintBottom_toBottomOf="@id/avatarCalc"
        app:layout_constraintStart_toEndOf="@id/avatarCalc" />

    <EditText
        android:id="@+id/etNum1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Número 1 (o base)"
        android:inputType="numberDecimal"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/avatarCalc" />

    <EditText
        android:id="@+id/etNum2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Número 2 (o potencia)"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/etNum1" />


    <LinearLayout
        android:id="@+id/layoutBotones1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etNum2">

        <Button android:id="@+id/btnSuma" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+" android:backgroundTint="#4FC3F7" android:elevation="0dp" android:stateListAnimator="@null" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnResta" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:backgroundTint="#4FC3F7" android:elevation="0dp" android:stateListAnimator="@null" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnMulti" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="*" android:backgroundTint="#4FC3F7" android:elevation="0dp" android:stateListAnimator="@null" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnDiv" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="/" android:backgroundTint="#4FC3F7" android:elevation="0dp" android:stateListAnimator="@null" android:layout_margin="2dp"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutBotones2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutBotones1">

        <Button
            android:id="@+id/btnExp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EXP (^)"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnRaiz"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RAÍZ (√)"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvResultadoCalc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado: 0.0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/layoutBotones2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnRegresar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REGRESAR"
        android:backgroundTint="#757575"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>