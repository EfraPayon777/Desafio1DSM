<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <View
        android:id="@+id/headerCalc"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#4FC3F7"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgToolIcon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginStart="24dp"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/mi_foto"
        android:background="#FFFFFF"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="@id/headerCalc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerCalc"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Calculadora Básica"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imgToolIcon"
        app:layout_constraintStart_toEndOf="@id/imgToolIcon"
        app:layout_constraintTop_toTopOf="@id/imgToolIcon" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/inputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerCalc">

        <EditText
            android:id="@+id/etNum1"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:color/white"
            android:hint="Primer número"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:textColor="#263238"
            android:textColorHint="#BDBDBD" />

        <EditText
            android:id="@+id/etNum2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@android:color/white"
            android:hint="Segundo número"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:textColor="#263238"
            android:textColorHint="#BDBDBD" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <GridLayout
        android:id="@+id/operatorGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/inputArea">

        <Button
            android:id="@+id/btnSuma"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Suma (+)"
            app:cornerRadius="4dp" />

        <Button
            android:id="@+id/btnResta"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Resta (-)"
            app:cornerRadius="4dp" />

        <Button
            android:id="@+id/btnMulti"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Multi (*)"
            app:cornerRadius="4dp" />

        <Button
            android:id="@+id/btnDiv"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#4FC3F7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Div (/)"
            app:cornerRadius="4dp" />

        <Button
            android:id="@+id/btnPotencia"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#0097A7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Exp (x^y)"
            app:cornerRadius="4dp" />

        <Button
            android:id="@+id/btnRaiz"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:backgroundTint="#0097A7"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Raíz (√x)"
            app:cornerRadius="4dp" />
    </GridLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="#263238"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/operatorGrid">

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="Resultado: 0.0"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="← Volver al Menú"
        android:textColor="#757575"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>