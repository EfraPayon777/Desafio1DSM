<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background_flat">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DESAFÍO PRÁCTICO 1"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark_flat"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/btnEjercicio1"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Ejercicio 1: Promedio"
        android:backgroundTint="@color/primary_flat"
        app:cornerRadius="4dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <Button
        android:id="@+id/btnEjercicio2"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Ejercicio 2: Salario"
        android:backgroundTint="@color/primary_flat"
        app:cornerRadius="4dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/btnEjercicio1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnEjercicio3"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Ejercicio 3: Calculadora"
        android:backgroundTint="@color/primary_flat"
        app:cornerRadius="4dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/btnEjercicio2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>